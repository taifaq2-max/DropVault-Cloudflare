# ────────────────────────────────────────────────────────────────────────────
# VaultDrop — Environment configuration template
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Secret used to sign/verify session cookies and internal tokens.
# Generate with: openssl rand -hex 64
SESSION_SECRET=replace-with-a-long-random-string

# ── TLS certificate paths (production only) ───────────────────────────────────
# Absolute or relative paths on the Docker HOST to your TLS files.
# These are bind-mounted read-only into the nginx container.
#
# Let's Encrypt (certbot):
#   TLS_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
#   TLS_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
#
# Self-signed (local/testing — see DropVault-docker.md for generation command):
#   TLS_CERT_PATH=./certs/fullchain.pem
#   TLS_KEY_PATH=./certs/privkey.pem
TLS_CERT_PATH=./certs/fullchain.pem
TLS_KEY_PATH=./certs/privkey.pem

# ── hCaptcha (required in production) ─────────────────────────────────────────
# Register at https://dashboard.hcaptcha.com to obtain keys.
# HCAPTCHA_SECRET_KEY  — server-side secret; never expose to the browser.
# VITE_HCAPTCHA_SITE_KEY — public site key; baked into the Vite build.
#
# If HCAPTCHA_SECRET_KEY is absent the server skips verification (dev only).
# If VITE_HCAPTCHA_SITE_KEY is absent the widget is hidden (dev only).
#
# Docker builds: pass VITE_HCAPTCHA_SITE_KEY as a build-arg (see Dockerfile.frontend).
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# ── Optional ──────────────────────────────────────────────────────────────────

# Enable verbose request logging in the API server (default: false)
DEBUG=false

# Restrict CORS to a specific frontend origin (recommended in production).
# The API will only accept cross-origin requests from this URL.
# If unset: defaults to http://localhost:3000 in development; blocked in production.
FRONTEND_URL=https://yourdomain.com

# Set to "true" when the API server sits behind a trusted reverse-proxy (nginx/Cloudflare).
# Enables reading the real client IP from the X-Forwarded-For header (last hop).
# Leave unset or "false" when the API is exposed directly.
TRUST_PROXY=false
